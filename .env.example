# Database
POSTGRES_USER=portintel
POSTGRES_PASSWORD=portintel_secret
POSTGRES_DB=portintel
DATABASE_URL=postgresql://portintel:portintel_secret@localhost:5432/portintel

# Redis
REDIS_URL=redis://localhost:6379/0

# AIS Stream (https://aisstream.io — free account, get API key)
AISSTREAM_API_KEY=your_aisstream_api_key_here

# OpenWeatherMap Marine (https://openweathermap.org/api — free tier)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Map tiles: CARTO dark basemap is used (no key needed — completely free)

# Alert channels (optional — leave blank to disable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_FROM_EMAIL=alerts@portintel.local
ALERT_TO_EMAIL=ops@yourcompany.com

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Risk scoring thresholds
RISK_HIGH_THRESHOLD=70
RISK_MEDIUM_THRESHOLD=40
ALERT_COOLDOWN_HOURS=4

# API
API_SECRET_KEY=change_me_in_production_32_chars_min
CORS_ORIGINS=http://localhost:3000
